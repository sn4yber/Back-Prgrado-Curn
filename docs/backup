CREATE TYPE user_status AS ENUM ('active', 'inactive', 'banned');

CREATE TYPE role_name AS ENUM ('estudiante', 'egresado', 'administrativo', 'admin');

CREATE TYPE program_level AS ENUM ('tecnico', 'tecnologo', 'profesional', 'especializacion', 'maestria', 'doctorado');

CREATE TYPE connection_status AS ENUM ('pending', 'accepted', 'rejected', 'blocked');

CREATE TYPE post_type AS ENUM ('job', 'project', 'announcement', 'event', 'general');

CREATE TYPE post_visibility AS ENUM ('public', 'connections', 'private');

CREATE TYPE project_status AS ENUM ('draft', 'active', 'completed', 'archived');

CREATE TYPE mentorship_status AS ENUM ('pending', 'active', 'completed', 'rejected');

CREATE TYPE event_type AS ENUM ('employability', 'conference', 'networking', 'workshop', 'seminar');

CREATE TYPE emp_level AS ENUM ('junior', 'mid', 'senior', 'expert');

CREATE TYPE notification_type AS ENUM ('connection_request', 'connection_accepted', 'new_message', 'mentorship_request', 'mentorship_accepted', 'mentorship_rejected', 'new_comment', 'event_reminder', 'new_post');


CREATE TABLE programs (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name        VARCHAR(200) NOT NULL,
    faculty     VARCHAR(200) NOT NULL,
    level       program_level NOT NULL,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

COMMENT ON TABLE programs IS 'Programas académicos ofertados por la institución';

-- ============================================================
-- TABLA: users
-- ============================================================

CREATE TABLE users (
    id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name              VARCHAR(150) NOT NULL,
    email             VARCHAR(255) NOT NULL,
    password_hash     TEXT NOT NULL,
    program_id        UUID NOT NULL,
    graduation_date   DATE,
    status            user_status NOT NULL DEFAULT 'active',
    avatar_url        TEXT,
    bio               TEXT,
    created_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT users_email_unique UNIQUE (email),
    CONSTRAINT users_program_fk   FOREIGN KEY (program_id) REFERENCES programs (id) ON DELETE RESTRICT
);

CREATE INDEX idx_users_email      ON users (email);
CREATE INDEX idx_users_program_id ON users (program_id);
CREATE INDEX idx_users_status     ON users (status);

COMMENT ON TABLE  users                  IS 'Usuarios autenticados de la plataforma';
COMMENT ON COLUMN users.graduation_date  IS 'Solo aplica para egresados. NULL = estudiante activo';
COMMENT ON COLUMN users.password_hash    IS 'Hash bcrypt de la contraseña. Nunca almacenar texto plano';

-- ============================================================
-- TABLA: roles
-- ============================================================

CREATE TABLE roles (
    id         SERIAL PRIMARY KEY,
    name       role_name NOT NULL,

    CONSTRAINT roles_name_unique UNIQUE (name)
);



CREATE TABLE user_roles (
    user_id    UUID NOT NULL,
    role_id    INT  NOT NULL,
    assigned_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT user_roles_pk      PRIMARY KEY (user_id, role_id),
    CONSTRAINT user_roles_user_fk FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE,
    CONSTRAINT user_roles_role_fk FOREIGN KEY (role_id) REFERENCES roles (id) ON DELETE RESTRICT
);

CREATE INDEX idx_user_roles_user_id ON user_roles (user_id);
CREATE INDEX idx_user_roles_role_id ON user_roles (role_id);


CREATE TABLE connections (
    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    requester_id  UUID NOT NULL,
    addressee_id  UUID NOT NULL,
    status        connection_status NOT NULL DEFAULT 'pending',
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    -- Un usuario no puede conectarse consigo mismo
    CONSTRAINT connections_no_self_loop CHECK (requester_id <> addressee_id),

    -- Evitar conexiones duplicadas en ambas direcciones
    -- Forzamos que el UUID menor siempre sea requester a nivel de constraint
    -- La lógica de ordenamiento se maneja en la capa de aplicación
    CONSTRAINT connections_unique UNIQUE (requester_id, addressee_id),

    CONSTRAINT connections_requester_fk FOREIGN KEY (requester_id) REFERENCES users (id) ON DELETE CASCADE,
    CONSTRAINT connections_addressee_fk FOREIGN KEY (addressee_id) REFERENCES users (id) ON DELETE CASCADE
);

CREATE INDEX idx_connections_requester ON connections (requester_id);
CREATE INDEX idx_connections_addressee ON connections (addressee_id);
CREATE INDEX idx_connections_status    ON connections (status);

COMMENT ON TABLE  connections IS 'Relaciones de conexión entre usuarios. Bidireccional cuando status=accepted';
COMMENT ON COLUMN connections.status IS 'pending: esperando respuesta | accepted: conectados | rejected: rechazado | blocked: bloqueado';


CREATE TABLE posts (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    author_id       UUID NOT NULL,
    content         TEXT NOT NULL,
    type            post_type NOT NULL DEFAULT 'general',
    visibility      post_visibility NOT NULL DEFAULT 'public',
    reference_id    UUID,        -- ID opcional de entidad relacionada (evento, proyecto)
    reference_type  VARCHAR(50), -- 'event' | 'project' | NULL
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT posts_author_fk FOREIGN KEY (author_id) REFERENCES users (id) ON DELETE CASCADE,
    -- Si hay reference_id debe haber reference_type y viceversa
    CONSTRAINT posts_reference_consistency CHECK (
        (reference_id IS NULL AND reference_type IS NULL) OR
        (reference_id IS NOT NULL AND reference_type IS NOT NULL)
    )
);

CREATE INDEX idx_posts_author_id  ON posts (author_id);
CREATE INDEX idx_posts_type       ON posts (type);
CREATE INDEX idx_posts_visibility ON posts (visibility);
CREATE INDEX idx_posts_created_at ON posts (created_at DESC);

COMMENT ON TABLE  posts IS 'Publicaciones en el muro institucional';
COMMENT ON COLUMN posts.reference_id   IS 'UUID de entidad relacionada (evento, proyecto). Opcional';
COMMENT ON COLUMN posts.reference_type IS 'Tipo de entidad referenciada: event | project | NULL';

-- ============================================================
-- TABLA: comments
-- ============================================================

CREATE TABLE comments (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    post_id     UUID NOT NULL,
    author_id   UUID NOT NULL,
    content     TEXT NOT NULL,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT comments_post_fk   FOREIGN KEY (post_id)   REFERENCES posts (id) ON DELETE CASCADE,
    CONSTRAINT comments_author_fk FOREIGN KEY (author_id) REFERENCES users (id) ON DELETE CASCADE
);

CREATE INDEX idx_comments_post_id   ON comments (post_id);
CREATE INDEX idx_comments_author_id ON comments (author_id);

COMMENT ON TABLE comments IS 'Comentarios sobre publicaciones del muro';

-- ============================================================
-- TABLA: conversations
-- ============================================================

CREATE TABLE conversations (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    -- Forzamos user1_id < user2_id para evitar duplicados bidireccionales
    user1_id    UUID NOT NULL,
    user2_id    UUID NOT NULL,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT conversations_no_self_chat CHECK (user1_id <> user2_id),
    -- user1_id siempre debe ser el UUID lexicográficamente menor
    CONSTRAINT conversations_order_check CHECK (user1_id < user2_id),
    -- Garantiza que solo puede existir UNA conversación entre dos usuarios
    CONSTRAINT conversations_unique UNIQUE (user1_id, user2_id),

    CONSTRAINT conversations_user1_fk FOREIGN KEY (user1_id) REFERENCES users (id) ON DELETE CASCADE,
    CONSTRAINT conversations_user2_fk FOREIGN KEY (user2_id) REFERENCES users (id) ON DELETE CASCADE
);

CREATE INDEX idx_conversations_user1 ON conversations (user1_id);
CREATE INDEX idx_conversations_user2 ON conversations (user2_id);

COMMENT ON TABLE  conversations IS 'Canal de mensajería privada entre exactamente dos usuarios';
COMMENT ON COLUMN conversations.user1_id IS 'Siempre el UUID lexicográficamente menor. Constraint garantiza no duplicados';

-- ============================================================
-- TABLA: messages
-- ============================================================

CREATE TABLE messages (
    id               UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    conversation_id  UUID NOT NULL,
    sender_id        UUID NOT NULL,
    content          TEXT NOT NULL,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT messages_conversation_fk FOREIGN KEY (conversation_id) REFERENCES conversations (id) ON DELETE CASCADE,
    CONSTRAINT messages_sender_fk       FOREIGN KEY (sender_id)       REFERENCES users (id) ON DELETE CASCADE
);

-- Índice compuesto optimizado para cargar historial de mensajes ordenado
CREATE INDEX idx_messages_conversation_time ON messages (conversation_id, created_at DESC);
CREATE INDEX idx_messages_sender_id         ON messages (sender_id);

COMMENT ON TABLE messages IS 'Mensajes dentro de una conversación privada';

-- ============================================================
-- TABLA: projects
-- ============================================================

CREATE TABLE projects (
    id           UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    creator_id   UUID NOT NULL,
    title        VARCHAR(300) NOT NULL,
    description  TEXT,
    status       project_status NOT NULL DEFAULT 'draft',
    created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT projects_creator_fk FOREIGN KEY (creator_id) REFERENCES users (id) ON DELETE CASCADE
);

CREATE INDEX idx_projects_creator_id ON projects (creator_id);
CREATE INDEX idx_projects_status     ON projects (status);

COMMENT ON TABLE  projects IS 'Proyectos académicos creados por estudiantes o egresados';
COMMENT ON COLUMN projects.creator_id IS 'Debe ser usuario con rol estudiante o egresado. Validar en capa de aplicación';

-- ============================================================
-- TABLA: mentorships
-- ============================================================

CREATE TABLE mentorships (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id  UUID NOT NULL,
    mentor_id   UUID NOT NULL,
    status      mentorship_status NOT NULL DEFAULT 'pending',
    start_date  DATE,
    end_date    DATE,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    -- No puede existir más de una mentoría activa por proyecto
    CONSTRAINT mentorships_unique_active UNIQUE (project_id, mentor_id),

    CONSTRAINT mentorships_project_fk FOREIGN KEY (project_id) REFERENCES projects (id) ON DELETE CASCADE,
    CONSTRAINT mentorships_mentor_fk  FOREIGN KEY (mentor_id)  REFERENCES users (id) ON DELETE CASCADE,

    -- La fecha de fin no puede ser anterior a la de inicio
    CONSTRAINT mentorships_dates_check CHECK (end_date IS NULL OR end_date >= start_date)
);

CREATE INDEX idx_mentorships_project_id ON mentorships (project_id);
CREATE INDEX idx_mentorships_mentor_id  ON mentorships (mentor_id);
CREATE INDEX idx_mentorships_status     ON mentorships (status);

COMMENT ON TABLE  mentorships IS 'Relación formal de mentoría entre un egresado y un proyecto';
COMMENT ON COLUMN mentorships.mentor_id IS 'Debe ser usuario con rol egresado. Validar en capa de aplicación o con trigger';

-- ============================================================
-- TABLA: events
-- ============================================================

CREATE TABLE events (
    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title         VARCHAR(300) NOT NULL,
    description   TEXT,
    type          event_type NOT NULL,
    event_date    TIMESTAMPTZ NOT NULL,
    location      VARCHAR(300),
    capacity      INT,
    created_by    UUID NOT NULL,
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT events_capacity_positive CHECK (capacity IS NULL OR capacity > 0),
    CONSTRAINT events_created_by_fk FOREIGN KEY (created_by) REFERENCES users (id) ON DELETE RESTRICT
);

CREATE INDEX idx_events_event_date  ON events (event_date);
CREATE INDEX idx_events_type        ON events (type);
CREATE INDEX idx_events_created_by  ON events (created_by);

COMMENT ON TABLE events IS 'Eventos institucionales: ferias de empleo, conferencias, networking';

-- ============================================================
-- TABLA: event_registrations  (N:N entre events y users)
-- ============================================================

CREATE TABLE event_registrations (
    event_id     UUID NOT NULL,
    user_id      UUID NOT NULL,
    registered_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT event_registrations_pk       PRIMARY KEY (event_id, user_id),
    CONSTRAINT event_registrations_event_fk FOREIGN KEY (event_id) REFERENCES events (id) ON DELETE CASCADE,
    CONSTRAINT event_registrations_user_fk  FOREIGN KEY (user_id)  REFERENCES users  (id) ON DELETE CASCADE
);

CREATE INDEX idx_event_registrations_user_id  ON event_registrations (user_id);
CREATE INDEX idx_event_registrations_event_id ON event_registrations (event_id);

COMMENT ON TABLE event_registrations IS 'Inscripciones de usuarios a eventos institucionales';

-- ============================================================
-- TABLA: employability_evaluations
-- ============================================================

CREATE TABLE employability_evaluations (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id     UUID NOT NULL,
    level       emp_level NOT NULL,
    strengths   TEXT,
    weaknesses  TEXT,
    notes       TEXT,
    created_by  UUID NOT NULL,  -- Administrativo que creó la evaluación
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT empl_eval_user_fk    FOREIGN KEY (user_id)    REFERENCES users (id) ON DELETE CASCADE,
    CONSTRAINT empl_eval_creator_fk FOREIGN KEY (created_by) REFERENCES users (id) ON DELETE RESTRICT
);

CREATE INDEX idx_empl_eval_user_id    ON employability_evaluations (user_id);
CREATE INDEX idx_empl_eval_created_at ON employability_evaluations (created_at DESC);

COMMENT ON TABLE  employability_evaluations IS 'Evaluaciones de empleabilidad de egresados';
COMMENT ON COLUMN employability_evaluations.created_by IS 'Usuario administrativo que generó la evaluación';



CREATE TABLE notifications (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID NOT NULL,           -- Receptor de la notificación
    type            notification_type NOT NULL,
    reference_id    UUID,                    -- ID del objeto relacionado
    reference_type  VARCHAR(50),             -- 'connection' | 'message' | 'mentorship' | 'event' | 'post'
    message         TEXT,                    -- Texto descriptivo opcional
    read_at         TIMESTAMPTZ,             -- NULL = no leída
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT notifications_user_fk FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE
);

CREATE INDEX idx_notifications_user_id   ON notifications (user_id);
CREATE INDEX idx_notifications_read_at   ON notifications (user_id, read_at) WHERE read_at IS NULL;
CREATE INDEX idx_notifications_created   ON notifications (created_at DESC);

COMMENT ON TABLE  notifications IS 'Notificaciones del sistema para cada usuario';
COMMENT ON COLUMN notifications.read_at IS 'NULL = notificación no leída. Se actualiza al marcarla como leída';

